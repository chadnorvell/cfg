{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "-y"
      ]
    },
    "graphite": {
      "command": "gt",
      "args": [
        "mcp"
      ]
    },
    "tidewave": {
      "serverUrl": "http://localhost:4000/tidewave/mcp"
    }
  }
}
